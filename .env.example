# Copy this file to ".env" (same folder as fetch_data.py) and fill in real values.
# NEVER commit or share a .env that contains real keys.
PORT = 3245

# Anthropic — Admin/analytics-scoped key (Console > Organization settings > Admin keys,
# or the Enterprise analytics keys page). Used for org usage & cost.
STANDARD_ANTHROPIC_KEY=

# GitHub — token with read:org (and manage_billing:copilot) for Copilot metrics + seats.
GITHUB_TOKEN=

# Your GitHub org login as it appears in github.com/<org>
# GITHUB_ORG=scrapinghub
GITHUB_ORG=

# Look-back window in days
DAYS=30
